# In .env kopieren und ausfüllen — .env wird NIE committet (.gitignore)
# API-Key existiert NUR hier auf dem Server, niemals im Client-Code
ANTHROPIC_API_KEY=sk-ant-...

# Standard-Modell (Budget-Regel: Sonnet 5; Opus 4.8 nur manuell zum Vergleich)
CLAUDE_MODEL=claude-sonnet-5

# Server-Port (optional, Default 3001)
SERVER_PORT=3001

# Optional: Zugangscode für die veröffentlichte App (schützt dein API-Budget).
# Leer/weggelassen = kein Schutz (lokal ok). Auf dem Hosting unbedingt setzen!
# ACCESS_CODE=dein-geheimer-code

# Optional: zusätzliche erlaubte Browser-Origins (kommagetrennt), z. B. GitHub Pages:
# CLIENT_ORIGINS=https://DEIN-GITHUB-NAME.github.io
